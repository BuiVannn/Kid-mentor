<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BRAND BAR — PTIT + CTS logos (copyright / attribution strip)    -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Thin top accent line -->
    <View
        android:id="@+id/brandAccentLine"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="#D30005"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Brand bar background (semi-transparent white) -->
    <View
        android:id="@+id/brandBarBg"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="#F5F5F5"
        app:layout_constraintTop_toBottomOf="@id/brandAccentLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CTS Logo — left side -->
    <ImageView
        android:id="@+id/ivBrandCts"
        android:layout_width="72dp"
        android:layout_height="56dp"
        android:src="@drawable/logo_cts"
        android:scaleType="fitCenter"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Vertical separator -->
    <View
        android:id="@+id/brandSeparator"
        android:layout_width="1dp"
        android:layout_height="28dp"
        android:background="#CACACB"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toEndOf="@id/ivBrandCts" />

    <!-- App name & institution -->
    <LinearLayout
        android:id="@+id/brandTextBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toEndOf="@id/brandSeparator"
        app:layout_constraintEnd_toStartOf="@id/ivBrandPtit">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PTALK KIDS"
            android:textSize="12sp"
            android:textColor="#111111"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lab CTS · PTIT"
            android:textSize="10sp"
            android:textColor="#707072"
            android:fontFamily="sans-serif"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <!-- PTIT Logo — right side -->
    <ImageView
        android:id="@+id/ivBrandPtit"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/logo_ptit"
        android:scaleType="fitCenter"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom border of brand bar -->
    <View
        android:id="@+id/brandBarBottomLine"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E5E5E5"
        app:layout_constraintTop_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  GREETING TEXTS                                                    -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xin chào!"
        android:textSize="@dimen/text_greeting"
        android:textColor="#6BAF8A"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/brandBarBottomLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hôm nay, tớ có thể giúp gì cho cậu?"
        android:textSize="@dimen/text_sub_greeting"
        android:textStyle="bold"
        android:textColor="#2E7D52"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  WAVEFORM + CHARACTER (giữ nguyên thứ tự z-order gốc)            -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- ① SÓNG ÂM — khai báo TRƯỚC ảnh để nằm phía sau -->
    <com.buivan.ptalk_child.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="0dp"
        android:layout_height="@dimen/waveform_height"
        app:layout_constraintTop_toBottomOf="@id/tvSubGreeting"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ② ẢNH NHÂN VẬT — khai báo SAU, nổi lên trên sóng -->
    <ImageView
        android:id="@+id/ivCharacter"
        android:layout_width="@dimen/character_size"
        android:layout_height="@dimen/character_size"
        android:src="@drawable/char_idle1"
        android:scaleType="centerCrop"
        android:contentDescription="AI character"
        app:layout_constraintTop_toBottomOf="@id/tvSubGreeting"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BOTTOM CONTROLS                                                   -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Text trạng thái -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chạm để ghi âm"
        android:textSize="@dimen/text_status"
        android:textColor="#8BAF9A"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnCancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Nút cancel (chỉ hiện khi PLAYING) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCancel"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="⏹  Dừng lại"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_cancel_button"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone"
        android:elevation="4dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Nút mic hold to talk -->
    <ImageButton
        android:id="@+id/btnHoldToTalk"
        android:layout_width="@dimen/btn_mic_size"
        android:layout_height="@dimen/btn_mic_size"
        android:src="@drawable/ic_mic_custom"
        android:background="@drawable/bg_hold_button"
        android:scaleType="centerInside"
        android:padding="18dp"
        android:layout_marginBottom="32dp"
        android:elevation="6dp"
        android:contentDescription="Ghi âm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
