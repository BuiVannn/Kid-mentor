<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#E9FAF2" />
        </shape>
    </item>
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#67DDB0"
                android:endColor="#42B788" />
            <stroke
                android:width="2dp"
                android:color="#F9FFFC" />
        </shape>
    </item>
</layer-list>
